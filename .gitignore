# Dependency directories (crucial to ignore)
**/node_modules/
node_modules/

# Local environment configuration (prevents API key leakage)
**/.env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Production builds
**/build/
**/dist/

# SQLite databases
**/database/*.db
**/*.db
**/*.db-journal
**/*.sqlite

# Logs and diagnostics
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System files
.DS_Store
Thumbs.db
